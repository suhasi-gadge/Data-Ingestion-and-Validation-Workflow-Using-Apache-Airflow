# Copy this file to `.env` before running `docker compose up`.
#
# On Linux you should set AIRFLOW_UID to your numeric user ID so that files
# created by the Airflow containers (logs, the SQLite db) are owned by you on
# the host. The official Airflow compose recommends this:
#   echo "AIRFLOW_UID=$(id -u)" >> .env
# On macOS / Windows the default 50000 is fine.
AIRFLOW_UID=50000

# Initial admin login created by the airflow-init service.
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Comma-separated list of tickers to ingest. Optional; defaults to AAPL,MSFT,GOOG,SPY.
# AIRFLOW_TICKERS=AAPL,MSFT,GOOG,SPY,NVDA
